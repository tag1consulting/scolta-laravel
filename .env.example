# Scolta AI Search Configuration
# Copy these to your .env file and customize as needed.

# AI Provider: 'anthropic' or 'openai' (or 'laravel' for Laravel AI SDK)
SCOLTA_AI_PROVIDER=anthropic

# API key for AI features (query expansion, summarization, follow-ups)
# Required for AI features. Leave empty to disable AI.
SCOLTA_API_KEY=

# AI model identifier
SCOLTA_AI_MODEL=claude-sonnet-4-5-20250514

# Custom API base URL (leave empty for provider defaults)
SCOLTA_AI_BASE_URL=

# AI feature toggles
SCOLTA_AI_EXPAND=true
SCOLTA_AI_SUMMARIZE=true
SCOLTA_MAX_FOLLOWUPS=3

# Site identity (used in AI prompts)
SCOLTA_SITE_NAME=
SCOLTA_SITE_DESCRIPTION=

# Pagefind binary path (leave empty for auto-detection)
SCOLTA_PAGEFIND_BINARY=

# Build and output directories
SCOLTA_BUILD_DIR=
SCOLTA_OUTPUT_DIR=

# Auto-rebuild index when content changes
SCOLTA_AUTO_REBUILD=false

# Cache TTL for AI responses in seconds (default: 30 days)
SCOLTA_CACHE_TTL=2592000

# Rate limiting: API requests per minute per IP
SCOLTA_RATE_LIMIT=30
